# ───────────────────────────────────────────────────────────────
# Credenciais do MongoDB (lidas pelo docker-compose.yml)
# ───────────────────────────────────────────────────────────────
MONGO_USER=ellis
MONGO_PASSWORD=troque-esta-senha
MONGO_DB=ellis

# ───────────────────────────────────────────────────────────────
# Aplicação (Nuxt). O usuário/senha abaixo devem bater com os de cima.
# authSource=admin é necessário porque o usuário root é criado no banco "admin".
# ───────────────────────────────────────────────────────────────
NUXT_MONGODB_URI=mongodb://ellis:troque-esta-senha@localhost:27017/ellis?authSource=admin
NUXT_MONGODB_DB=ellis

# Segredo da sessão (>= 32 caracteres). Gere com: openssl rand -base64 32
NUXT_SESSION_PASSWORD=troque-este-segredo-por-uma-string-longa-e-aleatoria

# Admin semeado no primeiro boot (criado se não existir nenhum admin)
NUXT_ADMIN_EMAIL=larissamilitao@ellisstudio.com.br
NUXT_ADMIN_PASSWORD=troque-esta-senha
